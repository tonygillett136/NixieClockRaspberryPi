[Unit]
Description=Nixie Clock Web Controller
After=network.target

[Service]
ExecStart=/usr/bin/python3 /home/pi/NixieClockRaspberryPi/WebNixie/nixie_web.py --port 80
WorkingDirectory=/home/pi/NixieClockRaspberryPi/WebNixie
StandardOutput=journal
StandardError=journal
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
